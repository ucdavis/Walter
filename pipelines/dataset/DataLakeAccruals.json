{
	"name": "DataLakeAccruals",
	"properties": {
		"linkedServiceName": {
			"referenceName": "Walter_Storage",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Year": {
				"type": "string"
			},
			"Month": {
				"type": "string"
			},
			"Day": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@{concat(dataset().Day, '.parquet')}",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@{concat(dataset().Year, '/', dataset().Month)}",
					"type": "Expression"
				},
				"fileSystem": "accruals"
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	}
}