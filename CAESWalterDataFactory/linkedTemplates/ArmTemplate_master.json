{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "CAESWalterDataFactory"
		},
		"ROBERTO_WalterDev_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ROBERTO_WalterDev'"
		},
		"ROBERTO_WalterProd_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ROBERTO_WalterProd'"
		},
		"Roberto_WalterTest_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Roberto_WalterTest'"
		},
		"CAESDOKVprod_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://CAES-DO-KV-prod-westUS2.vault.azure.net/"
		},
		"ROBERTO_WalterDev_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "caes-roberto"
		},
		"ROBERTO_WalterDev_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "WalterDev"
		},
		"ROBERTO_WalterDev_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "walter_adf"
		},
		"ROBERTO_WalterProd_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "caes-roberto"
		},
		"ROBERTO_WalterProd_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "WalterProd"
		},
		"ROBERTO_WalterProd_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "walter_adf"
		},
		"Roberto_WalterTest_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "caes-roberto"
		},
		"Roberto_WalterTest_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "WalterTest"
		},
		"Roberto_WalterTest_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "walter_adf"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "CAESWalterDataFactory_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ROBERTO_WalterDev_password": {
						"value": "[parameters('ROBERTO_WalterDev_password')]"
					},
					"ROBERTO_WalterProd_password": {
						"value": "[parameters('ROBERTO_WalterProd_password')]"
					},
					"Roberto_WalterTest_password": {
						"value": "[parameters('Roberto_WalterTest_password')]"
					},
					"CAESDOKVprod_properties_typeProperties_baseUrl": {
						"value": "[parameters('CAESDOKVprod_properties_typeProperties_baseUrl')]"
					},
					"ROBERTO_WalterDev_properties_typeProperties_server": {
						"value": "[parameters('ROBERTO_WalterDev_properties_typeProperties_server')]"
					},
					"ROBERTO_WalterDev_properties_typeProperties_database": {
						"value": "[parameters('ROBERTO_WalterDev_properties_typeProperties_database')]"
					},
					"ROBERTO_WalterDev_properties_typeProperties_userName": {
						"value": "[parameters('ROBERTO_WalterDev_properties_typeProperties_userName')]"
					},
					"ROBERTO_WalterProd_properties_typeProperties_server": {
						"value": "[parameters('ROBERTO_WalterProd_properties_typeProperties_server')]"
					},
					"ROBERTO_WalterProd_properties_typeProperties_database": {
						"value": "[parameters('ROBERTO_WalterProd_properties_typeProperties_database')]"
					},
					"ROBERTO_WalterProd_properties_typeProperties_userName": {
						"value": "[parameters('ROBERTO_WalterProd_properties_typeProperties_userName')]"
					},
					"Roberto_WalterTest_properties_typeProperties_server": {
						"value": "[parameters('Roberto_WalterTest_properties_typeProperties_server')]"
					},
					"Roberto_WalterTest_properties_typeProperties_database": {
						"value": "[parameters('Roberto_WalterTest_properties_typeProperties_database')]"
					},
					"Roberto_WalterTest_properties_typeProperties_userName": {
						"value": "[parameters('Roberto_WalterTest_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}