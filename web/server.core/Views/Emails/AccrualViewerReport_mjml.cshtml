@using server.core.Services
@model server.core.Services.AccrualViewerReportTemplateModel

@{
    Layout = "/Views/Shared/_NotificationLayout_mjml.cshtml";
    var payload = Model.Payload;
    var departmentBreakdown = payload.DepartmentBreakdown
        .OrderByDescending(row => row.LostCostMonth)
        .ThenBy(row => row.Department)
        .ToList();
}

<mj-section padding="@NotificationEmailLayoutSpacing.ContentPadding">
  <mj-column>
    <mj-text font-size="25px" font-weight="700" line-height="1.3" padding-bottom="10px">
      Monthly Vacation Accrual Report
    </mj-text>
    <mj-text padding="0px">
      Snapshot date: @AccrualEmailTemplateFormatting.Date(payload.SnapshotAsOfDate). Walter found @payload.AtCapCount.ToString("N0") employees at the vacation accrual cap and @payload.ApproachingCapCount.ToString("N0") approaching the cap.
    </mj-text>
  </mj-column>
</mj-section>

<mj-section padding="@NotificationEmailLayoutSpacing.ContentPadding">
  <mj-column width="50%">
    <mj-text color="#5d6b82" font-size="12px" font-weight="700" padding="0px 0px 4px 0px" text-transform="uppercase">
      Lost Cost This Month
    </mj-text>
    <mj-text font-size="24px" font-weight="700" padding="0px 0px 14px 0px">
      @AccrualEmailTemplateFormatting.Currency(payload.LostCostMonth)
    </mj-text>
  </mj-column>
  <mj-column width="50%">
    <mj-text color="#5d6b82" font-size="12px" font-weight="700" padding="0px 0px 4px 0px" text-transform="uppercase">
      Fiscal YTD Lost Cost
    </mj-text>
    <mj-text font-size="24px" font-weight="700" padding="0px 0px 14px 0px">
      @AccrualEmailTemplateFormatting.Currency(payload.LostCostYtd)
    </mj-text>
  </mj-column>
</mj-section>

<mj-section padding="@NotificationEmailLayoutSpacing.ContentPadding">
  <mj-column>
    <mj-table cellpadding="0" cellspacing="0" font-size="13px" line-height="1.45" role="presentation" padding="0px">
      <tr style="border-bottom:1px solid #d8e1ec;">
        <th align="left" width="31%" style="padding:0 10px 10px 0;color:#5d6b82;font-size:11px;font-weight:700;text-transform:uppercase;">Department</th>
        <th align="right" width="13%" style="padding:0 8px 10px 8px;color:#5d6b82;font-size:11px;font-weight:700;text-transform:uppercase;">Headcount</th>
        <th align="right" width="12%" style="padding:0 8px 10px 8px;color:#5d6b82;font-size:11px;font-weight:700;text-transform:uppercase;">At Cap</th>
        <th align="right" width="14%" style="padding:0 8px 10px 8px;color:#5d6b82;font-size:11px;font-weight:700;text-transform:uppercase;">Near Cap</th>
        <th align="right" width="15%" style="padding:0 8px 10px 8px;color:#5d6b82;font-size:11px;font-weight:700;text-transform:uppercase;">Month</th>
        <th align="right" width="15%" style="padding:0 0 10px 8px;color:#5d6b82;font-size:11px;font-weight:700;text-transform:uppercase;">YTD</th>
      </tr>
      @foreach (var row in departmentBreakdown)
      {
        <tr style="border-bottom:1px solid #eef3f8;vertical-align:top;">
          <td style="padding:12px 10px 12px 0;color:#172033;font-weight:600;">
            @row.Department<br />
            <span style="color:#5d6b82;font-weight:400;">@row.DepartmentCode</span>
          </td>
          <td align="right" style="padding:12px 8px;color:#172033;">@row.Headcount.ToString("N0")</td>
          <td align="right" style="padding:12px 8px;color:#172033;">@row.AtCapCount.ToString("N0")</td>
          <td align="right" style="padding:12px 8px;color:#172033;">@row.ApproachingCapCount.ToString("N0")</td>
          <td align="right" style="padding:12px 8px;color:#172033;font-weight:600;white-space:nowrap;">@AccrualEmailTemplateFormatting.Currency(row.LostCostMonth)</td>
          <td align="right" style="padding:12px 0 12px 8px;color:#172033;font-weight:600;white-space:nowrap;">@AccrualEmailTemplateFormatting.Currency(row.LostCostYtd)</td>
        </tr>
      }
    </mj-table>
  </mj-column>
</mj-section>

<mj-section padding="@NotificationEmailLayoutSpacing.ContentPadding">
  <mj-column>
    <mj-text color="#5d6b82" font-size="14px" padding="0px">
      Totals: @payload.TotalEmployees.ToString("N0") employees across @payload.TotalDepartments.ToString("N0") departments. Waste rate: @AccrualEmailTemplateFormatting.Percent(payload.WasteRate) across @payload.YtdMonthCount.ToString("N0") fiscal year months.
    </mj-text>
  </mj-column>
</mj-section>

@if (!string.IsNullOrWhiteSpace(Model.ButtonText) && !string.IsNullOrWhiteSpace(Model.ButtonUrl))
{
  @await Html.PartialAsync("/Views/Shared/_NotificationButton_mjml.cshtml", new server.core.Services.NotificationButtonModel(Model.ButtonText, Model.ButtonUrl))
}
