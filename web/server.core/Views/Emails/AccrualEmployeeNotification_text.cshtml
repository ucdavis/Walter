@using server.core.Services
@model server.core.Services.AccrualEmployeeNotificationTemplateModel
@{
    var payload = Model.Payload;
    var isAtCap = string.Equals(payload.Status, "AtCap", StringComparison.OrdinalIgnoreCase);
    var balanceHours = AccrualEmailTemplateFormatting.HoursValue(payload.BalanceHours);
    var capHours = AccrualEmailTemplateFormatting.HoursAbbreviation(payload.CapHours);
    var pctOfCap = AccrualEmailTemplateFormatting.Percent(payload.PctOfCap);
    var hoursToTake = Math.Max(0m, payload.BalanceHours + payload.AccrualHoursPerMonth - payload.CapHours);
    var hoursToTakeText = AccrualEmailTemplateFormatting.HoursUnit(hoursToTake);
    var lostCostMonth = AccrualEmailTemplateFormatting.Currency(payload.LostCostMonth);
    var lostCostYear = AccrualEmailTemplateFormatting.Currency(payload.LostCostMonth * 12m);
    var capStatus = isAtCap ? "at maximum" : "near maximum";
    const string aggieServiceUrl = "https://aggieservice.ucdavis.edu";
    const string trsUrl = "https://trs.ucdavis.edu/timesheet";
}
Dear **@Html.Raw(Model.GreetingName)**,

@if (Model.Variant == AccrualEmployeeNotificationVariant.FacultyAcademic)
{
    if (isAtCap)
    {
<text>As a fiscal year academic appointee, per UC policy (PPSM 2.210), vacation accrual stops entirely once the cap is reached. Your accruals are currently at maximum, and your funding source absorbs the cost of hours you would otherwise earn.
</text>
    }
    else
    {
<text>As a fiscal year academic appointee, per UC policy (PPSM 2.210), vacation accrual stops entirely once the cap is reached. Your accruals are nearing maximum, and your funding source will absorb the cost of hours you would otherwise earn if the cap is reached.
</text>
    }
}
else
{
    if (isAtCap)
    {
<text>Per UC policy (PPSM 2.210), your vacation accruals are currently at maximum because your balance has reached the cap. You will not accrue additional hours until your balance falls below the cap.
</text>
    }
    else
    {
<text>Per UC policy (PPSM 2.210), your vacation accruals are nearing maximum. You will not accrue additional hours once your balance reaches the cap, until your balance falls below the cap.
</text>
    }
}
Balance
@balanceHours
of @capHours

% of Cap
@pctOfCap
@capStatus

Hours to Take
@AccrualEmailTemplateFormatting.HoursValue(hoursToTake)
next month

Lost Accrual
@lostCostMonth
/mo - @lostCostYear/yr

Take Action
To stay below your maximum and avoid losing accrual, please plan to use @hoursToTakeText of vacation in the coming month.

@if (Model.Variant == AccrualEmployeeNotificationVariant.FacultyAcademic)
{
<text>Open AggieService
@aggieServiceUrl

Or reply to this email with the hours and dates you've already taken (e.g., "8 hours on March 17"). Please submit only hours you've taken - not planned hours. Your reply goes directly to AggieService for processing.
</text>
}
else
{
<text>Open TRS Time Reporting
@trsUrl
</text>
}

You may also donate vacation hours to the Catastrophic Leave program to support a colleague facing a serious illness or injury.

Best regards,
CAES Human Resources
