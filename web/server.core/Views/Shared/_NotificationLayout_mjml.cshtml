@using server.core.Services
@model server.core.Services.NotificationTemplateModelBase

@{
    const string PrimaryTextColor = "#1f1f1f";
    const string SecondaryTextColor = "#848484";
    const string BrandColor = "#0047ba";
    const string BodyBackgroundColor = "#fafafa";
    const string CardBackgroundColor = "#ffffff";
    const string CardBorderColor = "#e9e3ee";

    const string HeaderLogoPadding = "0 10px 0 0";
    const string ButtonInnerPadding = "13px 24px";
    const string FooterTextPadding = "0px";
    const string FooterLogoPadding = "14px 0 0 0";
    const string FooterLogoWidth = "100";

    var cardBorder = $"1px solid {CardBorderColor}";
    var hasAppHomeUrl = !string.IsNullOrWhiteSpace(Model.AppHomeUrl);
    var hasUniversityHomeUrl = !string.IsNullOrWhiteSpace(Model.UniversityHomeUrl);
}
<!doctype html>
<mjml>
  <mj-head>
    <mj-preview>@Model.AppName notification</mj-preview>
    <mj-raw>
      <meta name="color-scheme" content="light dark" />
      <meta name="supported-color-schemes" content="light dark" />
    </mj-raw>
    <mj-attributes>
      <mj-all font-family="proxima-nova, Arial, Helvetica, sans-serif" />
      <mj-text color="@PrimaryTextColor" font-size="16px" line-height="1.65" />
      <mj-button background-color="@BrandColor"
                 color="#ffffff"
                 border-radius="4px"
                 font-size="16px"
                 font-weight="600"
                 inner-padding="@ButtonInnerPadding" />
    </mj-attributes>
    <mj-style>
      :root {
        color-scheme: light dark;
        supported-color-schemes: light dark;
      }

      .dark-logo {
        display: none !important;
        mso-hide: all !important;
        max-height: 0 !important;
        overflow: hidden !important;
      }

      @@media (prefers-color-scheme: dark) {
        body,
        .dm-body {
          background-color: #111827 !important;
        }

        .dm-card,
        .dm-card > table,
        .dm-card td {
          background-color: #1f2937 !important;
          border-color: #485466 !important;
        }

        .dm-panel,
        .dm-panel > table,
        .dm-panel td {
          background-color: #273243 !important;
          border-color: #485466 !important;
        }

        .dm-callout,
        .dm-callout > table,
        .dm-callout td {
          background-color: #1e3a5f !important;
          border-color: #6aa7ff !important;
        }

        .dm-border,
        .dm-border > table,
        .dm-border td {
          border-color: #485466 !important;
        }

        .dm-text div,
        .dm-text a,
        .dm-title,
        .dm-title a {
          color: #f3f4f6 !important;
        }

        .dm-muted div,
        .dm-muted span,
        .dm-muted a {
          color: #cbd5e1 !important;
        }

        .dm-button a {
          background-color: #2563eb !important;
          color: #ffffff !important;
        }

        .dm-table table,
        .dm-table th,
        .dm-table td,
        .dm-table span {
          color: #f3f4f6 !important;
          border-color: #485466 !important;
        }

        .light-logo {
          display: none !important;
          mso-hide: all !important;
          max-height: 0 !important;
          overflow: hidden !important;
        }

        .dark-logo {
          display: block !important;
          max-height: none !important;
          overflow: visible !important;
        }
      }

      [data-ogsc] body,
      [data-ogsc] .dm-body {
        background-color: #111827 !important;
      }

      [data-ogsc] .dm-card,
      [data-ogsc] .dm-card > table,
      [data-ogsc] .dm-card td {
        background-color: #1f2937 !important;
        border-color: #485466 !important;
      }

      [data-ogsc] .dm-panel,
      [data-ogsc] .dm-panel > table,
      [data-ogsc] .dm-panel td {
        background-color: #273243 !important;
        border-color: #485466 !important;
      }

      [data-ogsc] .dm-callout,
      [data-ogsc] .dm-callout > table,
      [data-ogsc] .dm-callout td {
        background-color: #1e3a5f !important;
        border-color: #6aa7ff !important;
      }

      [data-ogsc] .dm-border,
      [data-ogsc] .dm-border > table,
      [data-ogsc] .dm-border td {
        border-color: #485466 !important;
      }

      [data-ogsc] .dm-text div,
      [data-ogsc] .dm-text a,
      [data-ogsc] .dm-title,
      [data-ogsc] .dm-title a {
        color: #f3f4f6 !important;
      }

      [data-ogsc] .dm-muted div,
      [data-ogsc] .dm-muted span,
      [data-ogsc] .dm-muted a {
        color: #cbd5e1 !important;
      }

      [data-ogsc] .dm-button a {
        background-color: #2563eb !important;
        color: #ffffff !important;
      }

      [data-ogsc] .dm-table table,
      [data-ogsc] .dm-table th,
      [data-ogsc] .dm-table td,
      [data-ogsc] .dm-table span {
        color: #f3f4f6 !important;
        border-color: #485466 !important;
      }

      [data-ogsc] .light-logo {
        display: none !important;
        mso-hide: all !important;
        max-height: 0 !important;
        overflow: hidden !important;
      }

      [data-ogsc] .dark-logo {
        display: block !important;
        max-height: none !important;
        overflow: visible !important;
      }
    </mj-style>
  </mj-head>
  <mj-body background-color="@BodyBackgroundColor"
           css-class="dm-body"
           width="@(string.IsNullOrWhiteSpace(Model.LayoutWidth) ? "640px" : Model.LayoutWidth)">
    @* Header *@
    <mj-section padding="@NotificationEmailLayoutSpacing.HeaderPadding">
      <mj-column>
        <mj-table cellpadding="0" cellspacing="0" role="presentation" padding="@NotificationEmailLayoutSpacing.MainSectionPadding">
          <tr>
            <td style="height:48px;line-height:0;mso-line-height-rule:exactly;padding:@(HeaderLogoPadding);vertical-align:middle;width:48px;">
              @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
              {
                if (hasAppHomeUrl)
                {
              <a class="light-logo" href="@Model.AppHomeUrl" style="display:block;text-decoration:none;">
                <img alt="" height="46" src="@Model.LogoUrl" style="border:0;display:block;height:46px;line-height:0;max-height:46px;max-width:46px;width:46px;" width="46" />
              </a>
                  if (!string.IsNullOrWhiteSpace(Model.DarkLogoUrl))
                  {
              <a class="dark-logo" href="@Model.AppHomeUrl" style="display:none;mso-hide:all;text-decoration:none;">
                <img alt="" height="46" src="@Model.DarkLogoUrl" style="border:0;display:block;height:46px;line-height:0;max-height:46px;max-width:46px;width:46px;" width="46" />
              </a>
                  }
                }
                else
                {
              <img alt="" class="light-logo" height="46" src="@Model.LogoUrl" style="border:0;display:block;height:46px;line-height:0;max-height:46px;max-width:46px;width:46px;" width="46" />
                  if (!string.IsNullOrWhiteSpace(Model.DarkLogoUrl))
                  {
              <img alt="" class="dark-logo" height="46" src="@Model.DarkLogoUrl" style="border:0;display:none;height:46px;line-height:0;max-height:46px;max-width:46px;mso-hide:all;width:46px;" width="46" />
                  }
                }
              }
            </td>
            <td style="height:48px;padding:0;vertical-align:middle;">
              <div class="dm-title" style="color:@(PrimaryTextColor);font-size:22px;font-weight:400;line-height:1.2;">
                @if (hasAppHomeUrl)
                {
                <a class="dm-title" href="@Model.AppHomeUrl" style="color:@(PrimaryTextColor);text-decoration:none;">@Model.AppName</a>
                }
                else
                {
                @Model.AppName
                }
              </div>
              <div class="dm-muted" style="color:@(SecondaryTextColor);font-size:12px;font-weight:700;letter-spacing:1.8px;line-height:1.5;text-transform:uppercase;">
                @if (hasAppHomeUrl)
                {
                <a class="dm-muted" href="@Model.AppHomeUrl" style="color:@(SecondaryTextColor);text-decoration:none;">Notification</a>
                }
                else
                {
                <text>Notification</text>
                }
              </div>
            </td>
          </tr>
        </mj-table>
      </mj-column>
    </mj-section>
    @* Main Section *@
    <mj-section background-color="@BrandColor"
                border-left="@cardBorder"
                border-radius="4px 4px 0 0"
                border-right="@cardBorder"
                padding="@NotificationEmailLayoutSpacing.MainSectionPadding">
      <mj-column padding="@NotificationEmailLayoutSpacing.MainColumnPadding">
        <mj-spacer height="4px" />
      </mj-column>
    </mj-section>
    <mj-section background-color="@CardBackgroundColor"
                border-bottom="@cardBorder"
                border-left="@cardBorder"
                border-radius="0 0 4px 4px"
                border-right="@cardBorder"
                css-class="dm-card"
                padding="@NotificationEmailLayoutSpacing.MainSectionPadding">
      <mj-column padding="@NotificationEmailLayoutSpacing.MainColumnPadding">
        @RenderBody()
      </mj-column>
    </mj-section>

    @if (!string.IsNullOrWhiteSpace(Model.AutomaticFooterText))
    {
    <mj-section padding="@NotificationEmailLayoutSpacing.ContentPadding">
      <mj-column>
        <mj-text align="center" css-class="dm-muted" font-size="12px" line-height="1.5" color="@SecondaryTextColor" padding="@FooterTextPadding">
          @Model.AutomaticFooterText
        </mj-text>
      </mj-column>
    </mj-section>
    }
    @if (!string.IsNullOrWhiteSpace(Model.UniversityLogoUrl))
    {
    <mj-section padding="@NotificationEmailLayoutSpacing.FooterLogoSectionPadding">
      <mj-column>
        <mj-table cellpadding="0" cellspacing="0" role="presentation" padding="@FooterLogoPadding">
          <tr>
            <td align="center">
              @if (hasUniversityHomeUrl)
              {
              <a class="light-logo" href="@Model.UniversityHomeUrl" style="display:inline-block;text-decoration:none;">
                <img alt="UC Davis" src="@Model.UniversityLogoUrl" width="@FooterLogoWidth" style="border:0;display:block;height:auto;line-height:100%;max-width:@(FooterLogoWidth)px;opacity:.55;outline:none;text-decoration:none;width:@(FooterLogoWidth)px;" />
              </a>
                if (!string.IsNullOrWhiteSpace(Model.DarkUniversityLogoUrl))
                {
              <a class="dark-logo" href="@Model.UniversityHomeUrl" style="display:none;mso-hide:all;text-decoration:none;">
                <img alt="UC Davis" src="@Model.DarkUniversityLogoUrl" width="@FooterLogoWidth" style="border:0;display:block;height:auto;line-height:100%;max-width:@(FooterLogoWidth)px;opacity:.75;outline:none;text-decoration:none;width:@(FooterLogoWidth)px;" />
              </a>
                }
              }
              else
              {
              <img alt="UC Davis" class="light-logo" src="@Model.UniversityLogoUrl" width="@FooterLogoWidth" style="border:0;display:block;height:auto;line-height:100%;max-width:@(FooterLogoWidth)px;opacity:.55;outline:none;text-decoration:none;width:@(FooterLogoWidth)px;" />
                if (!string.IsNullOrWhiteSpace(Model.DarkUniversityLogoUrl))
                {
              <img alt="UC Davis" class="dark-logo" src="@Model.DarkUniversityLogoUrl" width="@FooterLogoWidth" style="border:0;display:none;height:auto;line-height:100%;max-width:@(FooterLogoWidth)px;mso-hide:all;opacity:.75;outline:none;text-decoration:none;width:@(FooterLogoWidth)px;" />
                }
              }
            </td>
          </tr>
        </mj-table>
      </mj-column>
    </mj-section>
    }
  </mj-body>
</mjml>
